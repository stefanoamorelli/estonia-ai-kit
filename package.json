{
  "name": "estonia-ai-kit",
  "version": "1.1.0",
  "license": "AGPL-3.0",
  "private": true,
  "description": "Estonian Government APIs MCP Servers - Monorepo",
  "author": {
    "name": "Stefano Amorelli",
    "email": "stefano@amorelli.tech",
    "url": "https://amorelli.tech"
  },
  "workspaces": [
    "packages/*",
    "mcp/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write .",
    "clean": "nx run-many --target=clean --all && rm -rf node_modules",
    "dev": "nx run-many --target=dev --all --parallel",
    "publish:all": "nx run-many --target=publish --all"
  },
  "devDependencies": {
    "@nx/js": "^21.6.10",
    "@nx/node": "^21.6.10",
    "@nx/workspace": "^21.6.10",
    "@types/node": "^24.12.2",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "nx": "21.6.10",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.14.0",
    "dotenv": "^17.4.1",
    "node-cache": "^5.1.2"
  }
}
