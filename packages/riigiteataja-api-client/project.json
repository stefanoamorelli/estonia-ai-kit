{
  "name": "@estonia-ai-kit/riigiteataja-api-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/riigiteataja-api-client/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run build",
        "cwd": "packages/riigiteataja-api-client"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run test:run",
        "cwd": "packages/riigiteataja-api-client"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run lint",
        "cwd": "packages/riigiteataja-api-client"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run typecheck",
        "cwd": "packages/riigiteataja-api-client"
      }
    }
  }
}
